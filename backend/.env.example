# Meta App Dashboard에서 oEmbed Read Advanced Access 승인을 받은 앱의 토큰입니다.
# 실제 값은 .env에만 저장하고 Git에 커밋하지 마세요.
META_OEMBED_ACCESS_TOKEN=replace-with-rotated-app-access-token

# 앱이 지원하는 Graph API 버전으로 변경하세요.
META_GRAPH_API_VERSION=v21.0

# 선택 사항: 설정하면 iOS 요청에도 같은 X-API-Key가 필요합니다.
IDEA_EMBED_API_KEY=
HOST=127.0.0.1
PORT=8787
